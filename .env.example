# ──────────────────────────────────────────────────────────────────
#  ENVIRONMENT VARIABLES  —  copy this file to .env and fill in
#  NEVER commit .env to version control (it is in .gitignore)
# ──────────────────────────────────────────────────────────────────

# Contact form endpoint (formsubmit.co AJAX URL)
# Replace YOUR_EMAIL_HERE with your real email address.
# After first submission formsubmit will send you a confirmation email.
VITE_FORM_ENDPOINT=https://formsubmit.co/ajax/YOUR_EMAIL_HERE


# ──────────────────────────────────────────────────────────────────
#  ADDING IMAGES TO THE WEBSITE
# ──────────────────────────────────────────────────────────────────
#
#  Images are NOT configured here — use  src/data/siteConfig.js
#
#  Quick steps:
#   1. Drop your image into  public/images/  (e.g. avatar.jpg)
#   2. Open  src/data/siteConfig.js
#   3. Set the matching path, for example:
#
#        hero:    { avatar: '/images/avatar.jpg' }
#        about:   { photo:  '/images/about-photo.jpg' }
#        project: 'iac-security-terraform-aws': '/images/iac.png'
#
#   4. Save — image appears on the site immediately.
#
#  See  public/images/README.md  for recommended sizes and formats.
# ──────────────────────────────────────────────────────────────────
